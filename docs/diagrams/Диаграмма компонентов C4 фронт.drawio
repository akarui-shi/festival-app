<mxfile host="Electron">
  <diagram name="Диаграмма компонентов C4 фронт" id="c4-components-frontend">
    <mxGraphModel dx="1200" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="user" value="&lt;b&gt;Пользователь&lt;/b&gt;&lt;br&gt;[Person]&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Житель, организатор или администратор&lt;/font&gt;" style="html=1;fontSize=11;dashed=0;whiteSpace=wrap;fillColor=#083F75;strokeColor=#06315C;fontColor=#ffffff;shape=mxgraph.c4.person2;align=center;resizable=0;" vertex="1" parent="1">
          <mxGeometry x="500" y="30" width="200" height="170" as="geometry" />
        </mxCell>
        <mxCell id="boundary" value="&lt;b&gt;React SPA&lt;/b&gt;&lt;br&gt;[Container: React 18, TypeScript, Vite, React Router]" style="rounded=1;fontSize=11;whiteSpace=wrap;html=1;dashed=1;arcSize=20;fillColor=none;strokeColor=#666666;fontColor=#333333;align=left;verticalAlign=top;spacing=10;dashPattern=8 4;connectable=0;pointerEvents=0;" vertex="1" parent="1">
          <mxGeometry x="70" y="230" width="920" height="570" as="geometry" />
        </mxCell>
        <mxCell id="routing" value="&lt;b&gt;Маршрутизация и доступ&lt;/b&gt;&lt;br&gt;[Component: App.tsx, React Router, ProtectedRoute]&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Выбирает раздел приложения, проверяет авторизацию и роли&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#63BEF2;strokeColor=#2086C9;fontColor=#ffffff;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="410" y="290" width="250" height="115" as="geometry" />
        </mxCell>
        <mxCell id="state" value="&lt;b&gt;Состояние приложения&lt;/b&gt;&lt;br&gt;[Component: AuthContext, CityContext]&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Текущий пользователь, JWT, роли, выбранный город и localStorage&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#63BEF2;strokeColor=#2086C9;fontColor=#ffffff;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="710" y="290" width="250" height="115" as="geometry" />
        </mxCell>
        <mxCell id="public" value="&lt;b&gt;Публичная зона&lt;/b&gt;&lt;br&gt;[Component: public pages + PublicLayout]&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Главная, каталог, карточки мероприятий, карта, публикации, участники и рекомендации&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#63BEF2;strokeColor=#2086C9;fontColor=#ffffff;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="470" width="250" height="125" as="geometry" />
        </mxCell>
        <mxCell id="resident" value="&lt;b&gt;Кабинет жителя&lt;/b&gt;&lt;br&gt;[Component: resident pages]&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Профиль, избранное, билеты, QR-коды, платёжные страницы и подтверждение email&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#63BEF2;strokeColor=#2086C9;fontColor=#ffffff;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="410" y="470" width="250" height="125" as="geometry" />
        </mxCell>
        <mxCell id="staff" value="&lt;b&gt;Кабинеты организатора и администратора&lt;/b&gt;&lt;br&gt;[Component: OrganizerLayout, AdminLayout, role pages]&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Управление событиями, организациями, публикациями, промокодами, справочниками, модерацией и аналитикой&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#63BEF2;strokeColor=#2086C9;fontColor=#ffffff;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="710" y="470" width="250" height="125" as="geometry" />
        </mxCell>
