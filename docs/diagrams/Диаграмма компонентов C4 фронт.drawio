        <mxCell id="ui" value="&lt;b&gt;UI-компоненты&lt;/b&gt;&lt;br&gt;[Component: components/ui + common components]&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Формы, таблицы, карточки, диалоги, уведомления, состояния загрузки и переиспользуемые виджеты&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#63BEF2;strokeColor=#2086C9;fontColor=#ffffff;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="540" y="660" width="250" height="120" as="geometry" />
