# === База данных ===
DB_USER=postgres
DB_PASSWORD=changeme_strong_password

# === JWT (минимум 32 случайных символа, base64) ===
# Сгенерировать: openssl rand -base64 64
JWT_SECRET=changeme_replace_with_long_random_base64_string

# === URL приложения (без слэша в конце) ===
APP_BASE_URL=http://your-server-ip

# === Почта (SMTP) ===
MAIL_HOST=smtp.yandex.ru
MAIL_PORT=587
MAIL_USERNAME=your-mailbox@yandex.ru
MAIL_PASSWORD=your-app-password
NOTIFICATIONS_EMAIL_FROM=noreply@your-domain.ru

# === OAuth2 Google ===
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# === OAuth2 Яндекс ===
YANDEX_OAUTH_CLIENT_ID=your-yandex-client-id
YANDEX_OAUTH_CLIENT_SECRET=your-yandex-client-secret

# === ЮКасса (если не используется — оставьте как есть) ===
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
